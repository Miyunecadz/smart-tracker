{
  "name": "smart-tracker",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm --filter @smart-tracker/api dev\" \"pnpm --filter @smart-tracker/web dev\" --names api,web --prefix-colors blue,green",
    "build": "pnpm --filter @smart-tracker/api build && pnpm --filter @smart-tracker/web build",
    "lint": "pnpm --filter \"./apps/*\" --filter \"./packages/*\" lint",
    "codegen": "graphql-codegen --config codegen.ts",
    "predev": "pnpm codegen"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^7.1.3",
    "@graphql-codegen/typescript": "^6.0.2",
    "@graphql-codegen/typescript-operations": "^6.0.5",
    "@graphql-codegen/typescript-react-apollo": "^4.4.2",
    "concurrently": "^10.0.3",
    "graphql": "^16.9.0",
    "typescript": "^5.6.3"
  }
}
